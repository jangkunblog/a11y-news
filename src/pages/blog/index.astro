---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Summary 섹션 추출 함수
function extractSummary(body: string): string {
	// ## Summary 다음부터 다음 ## 제목 전까지의 내용 추출
	const summaryMatch = body.match(/## Summary\s*\n\n([\s\S]*?)(?=\n\n##|$)/);
	if (summaryMatch && summaryMatch[1]) {
		return summaryMatch[1].trim();
	}
	// Summary가 없으면 첫 번째 단락 반환
	const firstParagraph = body.split('\n\n').find(p => p.trim() && !p.startsWith('#'));
	return firstParagraph?.trim() || '';
}

// 각 게시물의 summary 추출
const posts = allPosts.map(post => ({
	...post,
	summary: extractSummary(post.body)
}));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				margin-bottom: 3rem;
				padding-bottom: 3rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			ul li:last-child {
				border-bottom: none;
			}
			.post-title {
				margin: 0 0 0.5rem 0;
				font-size: 1.8rem;
				font-weight: 600;
				line-height: 1.3;
			}
			.post-title a {
				color: rgb(var(--black));
				text-decoration: none;
				transition: color 0.2s ease;
			}
			.post-title a:hover {
				color: rgb(var(--accent));
			}
			.post-date {
				margin: 0 0 1rem 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.post-description {
				margin: 0;
				color: rgb(var(--gray-dark));
				line-height: 1.6;
			}
			@media (max-width: 720px) {
				.post-title {
					font-size: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<h2 class="post-title">
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h2>
								<p class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<p class="post-description">{post.summary}</p>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
